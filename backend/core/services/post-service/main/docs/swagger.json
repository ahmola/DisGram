{
    "swagger": "2.0",
    "info": {
        "description": "API built with Gin",
        "title": "Post API",
        "contact": {},
        "version": "2.0"
    },
    "host": "localhost:8083",
    "basePath": "/api/v2",
    "paths": {
        "/likes": {
            "post": {
                "description": "User add Like on the post. Cannot be duplicated",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "likes"
                ],
                "summary": "Create Like",
                "parameters": [
                    {
                        "description": "Like DTO",
                        "name": "like",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal.LikeRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal.LikeResponse"
                        }
                    }
                }
            }
        },
        "/likes/{id}": {
            "delete": {
                "description": "Delete the Like of Post by Like ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "likes"
                ],
                "summary": "Cancel Like",
                "parameters": [
                    {
                        "type": "string",
                        "description": "like ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "boolean"
                            }
                        }
                    }
                }
            }
        },
        "/posts": {
            "put": {
                "description": "Update the post",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Update Post",
                "parameters": [
                    {
                        "description": "Update Post",
                        "name": "post",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal.PostRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal.Post"
                        }
                    }
                }
            },
            "post": {
                "description": "Create a new Post",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Create Post",
                "parameters": [
                    {
                        "description": "PostDTO",
                        "name": "post",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal.PostRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal.Post"
                        }
                    },
                    "400": {
                        "description": "Wrong Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/posts/likes/{postId}": {
            "get": {
                "description": "Read all the likes of the specific post.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "likes"
                ],
                "summary": "List of Likes",
                "parameters": [
                    {
                        "type": "string",
                        "description": "post ID",
                        "name": "postId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/internal.LikeResponse"
                            }
                        }
                    }
                }
            }
        },
        "/posts/{id}": {
            "get": {
                "description": "Read Post and Images of the post",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Read Post Info",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Post ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal.Post"
                        }
                    }
                }
            },
            "delete": {
                "description": "Delete the post, images of the post, likes of the post",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Delete Post",
                "parameters": [
                    {
                        "type": "string",
                        "description": "게시글 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "성공 여부",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "boolean"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal.LikeRequest": {
            "type": "object",
            "properties": {
                "postId": {
                    "type": "integer"
                },
                "userId": {
                    "type": "integer"
                }
            }
        },
        "internal.LikeResponse": {
            "type": "object",
            "properties": {
                "Id": {
                    "type": "integer"
                },
                "postId": {
                    "type": "integer"
                },
                "userId": {
                    "type": "integer"
                }
            }
        },
        "internal.Post": {
            "type": "object",
            "properties": {
                "caption": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                },
                "userId": {
                    "type": "integer"
                }
            }
        },
        "internal.PostImageRequest": {
            "type": "object",
            "properties": {
                "extension": {
                    "type": "string"
                },
                "fileKey": {
                    "type": "string"
                },
                "postId": {
                    "type": "integer"
                },
                "seq": {
                    "type": "integer"
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "internal.PostRequest": {
            "type": "object",
            "properties": {
                "caption": {
                    "type": "string"
                },
                "postImage": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal.PostImageRequest"
                    }
                },
                "userId": {
                    "type": "integer"
                }
            }
        }
    }
}